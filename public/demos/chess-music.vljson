 },
 "windows": [
  {
   "type": "editor",
   "editorId": 1,
   "title": "Chess",
   "x": 20,
   "y": 20,
   "w": 640,
   "h": 560,
   "visible": true,
   "nochrome": false,
   "transparent": false,
   "audio": {
